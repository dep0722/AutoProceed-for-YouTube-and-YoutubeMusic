{
    "manifest_version": 3,
    "name": "AutoProceed",
    "version": "0.1",
    "description": "This extension can help you auto click the \"I understand and wish to proceed\" button on youtube and youtube music.",
    "content_scripts": [
        {
            "matches": [
            "https://www.youtube.com/*",
            "https://music.youtube.com/*"
            ],
            "js": [
            "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}